---
import Layout from '../layouts/Layout.astro';
import { roadmapThemes } from '../data/content';
import '../styles/app.css';
---

<Layout title="AI-900 Study Companion">
	<main class="page">
		<a href="#roadmap" class="skip-link" data-i18n="a11y.skipLink">Skip to study workspace</a>
		<header class="hero reveal">
			<div class="hero-top">
				<div>
					<p class="eyebrow">AI-900 Prep Workspace</p>
					<h1>Microsoft Certification Helper</h1>
					<p class="hero-copy" data-i18n="hero.copy">
						Quiz mode, exam mode, flashcards, an error journal, and a glossary with local progress stored
						in the browser database.
					</p>
				</div>
				<div class="hero-controls">
					<button id="theme-toggle" type="button" class="secondary theme-toggle">
						Switch to dark mode
					</button>
					<button id="language-toggle" type="button" class="secondary language-toggle" aria-label="Switch language to German">
						DE
					</button>
					<button id="settings-toggle" type="button" class="secondary settings-toggle" aria-label="Settings" data-i18n-aria-label="settings.title">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
					</button>
				</div>
			</div>
			<nav class="hero-modes" aria-label="Study modes" data-i18n-aria-label="tabs.ariaLabel">
				<button type="button" class="mode-btn" data-mode="quiz" data-tooltip="Answer questions with instant feedback and track your accuracy over time." data-i18n-tooltip="tooltip.quiz">
					<span class="mode-icon" aria-hidden="true">&#9997;</span>
					<span class="mode-label" data-i18n="tabs.quiz">Quiz</span>
					<span class="mode-desc" data-i18n="hero.modeQuizDesc">Instant feedback</span>
				</button>
				<button type="button" class="mode-btn" data-mode="exam" data-tooltip="Simulate a timed exam with 10 questions in 20 minutes and get a detailed review." data-i18n-tooltip="tooltip.exam">
					<span class="mode-icon" aria-hidden="true">&#128221;</span>
					<span class="mode-label" data-i18n="tabs.exam">Exam</span>
					<span class="mode-desc" data-i18n="hero.modeExamDesc">Timed simulation</span>
				</button>
				<button type="button" class="mode-btn" data-mode="flashcards" data-tooltip="Study AI-900 concepts with spaced repetition. Rate cards as Again, Good, or Easy." data-i18n-tooltip="tooltip.flashcards">
					<span class="mode-icon" aria-hidden="true">&#127183;</span>
					<span class="mode-label" data-i18n="tabs.flashcards">Flashcards</span>
					<span class="mode-desc" data-i18n="hero.modeFlashcardsDesc">Spaced repetition</span>
				</button>
				<button type="button" class="mode-btn" data-mode="glossary" data-tooltip="Browse and memorize AI-900 terms as flashcards with search and spaced repetition." data-i18n-tooltip="tooltip.glossary">
					<span class="mode-icon" aria-hidden="true">&#128214;</span>
					<span class="mode-label" data-i18n="tabs.glossary">Glossary</span>
					<span class="mode-desc" data-i18n="hero.modeGlossaryDesc">Term flashcards</span>
				</button>
				<button type="button" class="mode-btn" data-mode="journal" data-tooltip="Review your most frequent mistakes and practice the questions you got wrong." data-i18n-tooltip="tooltip.journal">
					<span class="mode-icon" aria-hidden="true">&#128203;</span>
					<span class="mode-label" data-i18n="tabs.journal">Error Journal</span>
					<span class="mode-desc" data-i18n="hero.modeJournalDesc">Review mistakes</span>
				</button>
			</nav>
		</header>

		<section class="card reveal" id="roadmap">
			<div class="section-head">
				<h2 data-i18n="roadmap.title">Roadmap</h2>
				<p id="roadmap-summary" class="meta">0 / 0 todos completed</p>
			</div>
			<div class="roadmap-grid">
				{
					roadmapThemes.map((theme) => (
						<article class="theme-card" data-roadmap-id={theme.id}>
							<h3>{theme.title}</h3>
							<p>{theme.goal}</p>
							<ul>
								{theme.todos.map((todo, todoIndex) => (
									<li>
										<label>
											<input type="checkbox" data-roadmap-key={`${theme.id}:${todoIndex}`} />
											<span>{todo}</span>
										</label>
									</li>
								))}
							</ul>
						</article>
					))
				}
			</div>
		</section>

		<section class="metrics reveal" aria-label="Progress metrics">
			<article class="metric"><p data-i18n="metrics.roadmap">Roadmap</p><strong id="metric-roadmap">0%</strong></article>
			<article class="metric"><p data-i18n="metrics.quizAccuracy">Quiz Accuracy</p><strong id="metric-accuracy">0%</strong></article>
			<article class="metric"><p data-i18n="metrics.bestExam">Best Exam</p><strong id="metric-exam">0%</strong></article>
			<article class="metric"><p data-i18n="metrics.dueCards">Due Cards</p><strong id="metric-due">0</strong></article>
			<article class="metric"><p data-i18n="metrics.journal">Error Journal</p><strong id="metric-journal">0</strong></article>
		</section>

		<!-- Quiz Overlay -->
		<div id="overlay-quiz" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-quiz-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-quiz-title" data-i18n="quiz.title">Quiz with instant feedback</h2>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<p id="quiz-progress" class="meta"></p>
					<div class="quiz-question-row">
						<p id="quiz-topic" class="chip"></p>
						<button id="quiz-bookmark" type="button" class="quiz-bookmark" aria-label="Save question" data-i18n-aria-label="quiz.bookmarkLabel">&#9825;</button>
					</div>
					<h4 id="quiz-question"></h4>
					<div id="quiz-options" class="option-list"></div>
					<div class="quiz-actions">
						<button id="quiz-hint" type="button" class="secondary" data-i18n="quiz.showHint">Show hint</button>
						<button id="quiz-skip" type="button" class="secondary" data-i18n="quiz.skip">Skip</button>
					</div>
					<p id="quiz-hint-text" class="hint-box" hidden></p>
					<p id="quiz-feedback" class="feedback" aria-live="polite"></p>
					<button id="quiz-next" type="button" class="primary" data-i18n="quiz.nextQuestion">Next question</button>
				</div>
			</div>
		</div>

		<!-- Exam Overlay -->
		<div id="overlay-exam" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-exam-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-exam-title" data-i18n="exam.title">Exam mode</h2>
					<p class="meta" data-i18n="exam.meta">10 questions, 20 minutes, mixed question types, and a detailed review.</p>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<div class="exam-top">
						<button id="exam-start" type="button" class="primary" data-i18n="exam.start">Start exam</button>
						<p id="exam-timer" class="timer" role="timer" aria-label="Time remaining: 20:00">20:00</p>
					</div>
					<div id="exam-stage" hidden>
						<p id="exam-progress" class="meta"></p>
						<h4 id="exam-question"></h4>
						<div id="exam-options" class="option-list"></div>
						<button id="exam-next" type="button" class="primary" disabled data-i18n="exam.nextQuestion">Next question</button>
					</div>
					<div id="exam-result" class="exam-result" aria-live="polite"></div>
					<div id="exam-review" class="exam-review"></div>
				</div>
			</div>
		</div>

		<!-- Flashcards Overlay -->
		<div id="overlay-flashcards" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-flashcards-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-flashcards-title" data-i18n="flashcards.title">Spaced Repetition</h2>
					<p class="meta" data-i18n="flashcards.meta">Rate each card: Again, Good, Easy.</p>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<div id="flashcard-box" class="flashcard" aria-live="polite">
						<p id="flashcard-topic" class="chip"></p>
						<h4 id="flashcard-front"></h4>
						<p id="flashcard-back" hidden></p>
					</div>
					<div class="flash-actions">
						<button id="flashcard-show" type="button" class="secondary" data-i18n="flashcards.showAnswer">Show answer</button>
						<div id="flashcard-grade-actions" class="grade-actions" hidden>
							<button id="flashcard-again" type="button" class="danger" data-i18n="flashcards.again">Again</button>
							<button id="flashcard-good" type="button" class="primary" data-i18n="flashcards.good">Good</button>
							<button id="flashcard-easy" type="button" class="secondary" data-i18n="flashcards.easy">Easy</button>
						</div>
					</div>
					<p id="flashcard-meta" class="meta"></p>
				</div>
			</div>
		</div>

		<!-- Glossary Overlay -->
		<div id="overlay-glossary" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-glossary-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-glossary-title" data-i18n="glossary.title">Glossary</h2>
					<p class="meta" data-i18n="glossary.metaFlashcard">Flip through AI-900 terms as flashcards.</p>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<div class="glossary-search-row">
						<label class="search-label" for="glossary-search" data-i18n="glossary.search">Search</label>
						<input id="glossary-search" type="search" placeholder="Term or keyword..." data-i18n-placeholder="glossary.placeholder" />
					</div>
					<div id="glossary-card-box" class="flashcard" aria-live="polite">
						<p id="glossary-card-count" class="chip"></p>
						<h4 id="glossary-card-front"></h4>
						<p id="glossary-card-back" hidden></p>
					</div>
					<div class="flash-actions">
						<button id="glossary-card-show" type="button" class="secondary" data-i18n="glossary.showDef">Show definition</button>
						<div id="glossary-grade-actions" class="grade-actions" hidden>
							<button id="glossary-card-again" type="button" class="danger" data-i18n="flashcards.again">Again</button>
							<button id="glossary-card-good" type="button" class="primary" data-i18n="flashcards.good">Good</button>
							<button id="glossary-card-easy" type="button" class="secondary" data-i18n="flashcards.easy">Easy</button>
						</div>
					</div>
					<p id="glossary-card-meta" class="meta"></p>
				</div>
			</div>
		</div>

		<!-- Journal Overlay -->
		<div id="overlay-journal" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-journal-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-journal-title" data-i18n="journal.title">Error Journal</h2>
					<p class="meta" data-i18n="journal.meta">Prioritized list of your missed questions.</p>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<div id="journal-list" class="journal-list" aria-live="polite"></div>
				</div>
			</div>
		</div>

		<!-- Settings Overlay -->
		<div id="overlay-settings" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-settings-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-settings-title" data-i18n="settings.title">Settings</h2>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<div class="settings-form">
						<label class="settings-row">
							<span data-i18n="settings.newCardsDay">New flashcards / day</span>
							<input id="setting-new-cards" type="number" min="1" max="50" value="20" />
						</label>
						<label class="settings-row">
							<span data-i18n="settings.newGlossaryDay">New glossary cards / day</span>
							<input id="setting-new-glossary" type="number" min="1" max="70" value="10" />
						</label>
						<label class="settings-row">
							<span data-i18n="settings.maxReviews">Max reviews / day</span>
							<input id="setting-max-reviews" type="number" min="10" max="500" value="100" />
						</label>
						<label class="settings-row">
							<span data-i18n="settings.goodMultiplier">Interval multiplier "Good"</span>
							<input id="setting-good-mult" type="number" min="1.0" max="5.0" step="0.1" value="2.0" />
						</label>
						<label class="settings-row">
							<span data-i18n="settings.easyMultiplier">Interval multiplier "Easy"</span>
							<input id="setting-easy-mult" type="number" min="1.5" max="7.0" step="0.1" value="3.0" />
						</label>
						<label class="settings-row">
							<span data-i18n="settings.lapseMinutes">Lapse interval (minutes)</span>
							<input id="setting-lapse" type="number" min="1" max="60" value="10" />
						</label>
					</div>
					<div class="settings-actions">
						<button id="settings-save" type="button" class="primary" data-i18n="settings.save">Save</button>
						<button id="settings-reset" type="button" class="secondary" data-i18n="settings.reset">Reset defaults</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Welcome Overlay -->
		<div id="overlay-welcome" class="overlay" role="dialog" aria-modal="true" aria-labelledby="overlay-welcome-title" hidden>
			<div class="overlay-backdrop"></div>
			<div class="overlay-container">
				<div class="overlay-header">
					<h2 id="overlay-welcome-title" data-i18n="welcome.title">Welcome to AI-900 Study Companion</h2>
					<button type="button" class="overlay-close" aria-label="Close" data-i18n-aria-label="overlay.close">&times;</button>
				</div>
				<div class="overlay-body">
					<p data-i18n="welcome.intro">This app helps you prepare for the Microsoft AI-900 certification. Here are the study modes:</p>
					<ul class="welcome-features">
						<li><span class="mode-icon" aria-hidden="true">&#9997;</span> <strong data-i18n="tabs.quiz">Quiz</strong> &mdash; <span data-i18n="welcome.quiz">Answer questions with instant feedback and track your accuracy.</span></li>
						<li><span class="mode-icon" aria-hidden="true">&#128221;</span> <strong data-i18n="tabs.exam">Exam</strong> &mdash; <span data-i18n="welcome.exam">Simulate a timed exam with 10 questions and detailed review.</span></li>
						<li><span class="mode-icon" aria-hidden="true">&#127183;</span> <strong data-i18n="tabs.flashcards">Flashcards</strong> &mdash; <span data-i18n="welcome.flashcards">Study concepts with spaced repetition scheduling.</span></li>
						<li><span class="mode-icon" aria-hidden="true">&#128214;</span> <strong data-i18n="tabs.glossary">Glossary</strong> &mdash; <span data-i18n="welcome.glossary">Browse and memorize AI-900 terms as flashcards.</span></li>
						<li><span class="mode-icon" aria-hidden="true">&#128203;</span> <strong data-i18n="tabs.journal">Error Journal</strong> &mdash; <span data-i18n="welcome.journal">Review and practice your most frequent mistakes.</span></li>
					</ul>
					<p class="meta" data-i18n="welcome.hint">Tip: Use keyboard shortcuts (D for dark mode, L for language) and the settings gear to customize your experience.</p>
					<button id="welcome-start" type="button" class="primary" data-i18n="welcome.start">Get started</button>
				</div>
			</div>
		</div>

		<details class="shortcuts-section reveal">
			<summary data-i18n="shortcuts.title">Keyboard shortcuts</summary>
			<div class="shortcuts-grid">
				<p><strong>Quiz / Exam:</strong> <span data-i18n="shortcuts.quiz">1-4 Answer | H Hint | S Skip | N Next</span></p>
				<p><strong>Flashcards / Glossary:</strong> <span data-i18n="shortcuts.flash">Space Reveal | 1 Again | 2 Good | 3 Easy</span></p>
				<p><strong>Global:</strong> <span data-i18n="shortcuts.global">D Dark mode | L Language | ESC Close overlay</span></p>
			</div>
		</details>

		<section class="reset-section reveal">
			<button id="reset-progress" type="button" class="danger" data-i18n="reset.button">Reset progress</button>
		</section>
	</main>

	<script>
		import '../scripts/app.js';
	</script>
</Layout>

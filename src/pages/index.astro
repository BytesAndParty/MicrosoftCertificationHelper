---
import Layout from '../layouts/Layout.astro';
import StudyWorkspace from '../components/study/StudyWorkspace';
import AccentSwitcherIsland from '../components/AccentSwitcherIsland';
import GlossaryIsland from '../components/GlossaryIsland';
import FlashcardsIsland from '../components/FlashcardsIsland';
import JournalIsland from '../components/JournalIsland';
import QuizIsland from '../components/QuizIsland';
import ExamIsland from '../components/ExamIsland';
import SettingsIsland from '../components/SettingsIsland';
import AiChatIsland from '../components/AiChatIsland';
import DashboardIsland from '../components/DashboardIsland';
import GlobalRuntime from '../components/GlobalRuntime';
import '../styles/study-workspace.css';
---

<Layout title="AI-900 Study Companion">
	<StudyWorkspace />
	<GlobalRuntime client:load />
	<AccentSwitcherIsland client:load />
	<GlossaryIsland client:only="react" />
	<FlashcardsIsland client:only="react" />
	<JournalIsland client:only="react" />
	<QuizIsland client:only="react" />
	<ExamIsland client:only="react" />
	<SettingsIsland client:only="react" />
	<DashboardIsland client:only="react" />
	<AiChatIsland client:only="react" />
</Layout>
